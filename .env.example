# Sanity project credentials — get these from sanity.io/manage after
# running `npx sanity login` and `npx sanity init` (see README for steps).
PUBLIC_SANITY_PROJECT_ID="your-project-id"
PUBLIC_SANITY_DATASET="production"
PUBLIC_SANITY_API_VERSION="2024-01-01"

# Write-access token for the one-time markdown -> Sanity migration script
# (scripts/migrate-stories-to-sanity.ts). Create it at
# sanity.io/manage -> API -> Tokens, with "Editor" permissions.
# Never commit this value or prefix it with PUBLIC_.
SANITY_API_TOKEN=""
