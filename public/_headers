# 'unsafe-inline' on script-src permits inline JSON-LD structured-data
# blocks. Tighten this with Astro's experimental CSP
# (auto-hashed inline scripts) once it stabilizes further:
# https://docs.astro.build/en/guides/security/#experimental-csp-support
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://buttondown.email; upgrade-insecure-requests
  Cache-Control: public, max-age=0, must-revalidate

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/*.xml
  Cache-Control: public, max-age=300, must-revalidate

/*.txt
  Cache-Control: public, max-age=300, must-revalidate
