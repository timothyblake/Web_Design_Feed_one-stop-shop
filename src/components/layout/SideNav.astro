---
import { CATEGORIES } from "../../consts";

interface Props {
  activeCategory?: string;
}

const { activeCategory } = Astro.props;
---

<aside
  class="hidden lg:flex flex-col gap-stack-md py-stack-lg w-64 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto pr-gutter shadow-[inset_-1px_0_0_rgba(0,0,0,0.15),1px_0_0_rgba(255,255,255,0.8)] dark:shadow-[inset_-1px_0_0_rgba(255,255,255,0.1),1px_0_0_rgba(0,0,0,0.5)]"
>
  <div class="px-3 mb-2">
    <h2
      class="font-headline-lg text-[22px] font-bold text-primary dark:text-inverse-on-surface"
    >
      Categories
    </h2>
    <p class="font-body-md text-body-md text-on-surface-variant mt-1">
      Filter your feed
    </p>
  </div>

  <nav aria-label="Categories" class="flex flex-col gap-1">
    <a
      href="/"
      aria-current={!activeCategory ? "page" : undefined}
      class={`rounded-xl p-3 font-label-md text-label-md flex items-center gap-3 transition-colors ${
        !activeCategory
          ? "bg-secondary text-on-secondary font-bold shadow-sm"
          : "text-primary dark:text-inverse-on-surface hover:bg-surface-variant font-semibold"
      }`}
    >
      <span class="material-symbols-outlined text-[20px]" aria-hidden="true"
        >apps</span
      >
      All Stories
    </a>
    {
      CATEGORIES.map((category) => (
        <a
          href={`/category/${category.slug}/`}
          aria-current={activeCategory === category.slug ? "page" : undefined}
          class={`rounded-xl p-3 font-label-md text-label-md flex items-center gap-3 transition-colors ${
            activeCategory === category.slug
              ? "bg-secondary text-on-secondary font-bold shadow-sm"
              : "text-primary dark:text-inverse-on-surface hover:bg-surface-variant font-semibold"
          }`}
        >
          <span
            class="material-symbols-outlined text-[20px]"
            style={`font-variation-settings: 'FILL' ${activeCategory === category.slug ? 1 : 0}`}
            aria-hidden="true"
          >
            {category.icon}
          </span>
          {category.label}
        </a>
      ))
    }
  </nav>

  <div class="mt-auto pt-6 shadow-[inset_0_1px_0_rgba(0,0,0,0.15),0_-1px_0_rgba(255,255,255,0.8)] dark:shadow-[inset_0_1px_0_rgba(255,255,255,0.1),0_-1px_0_rgba(0,0,0,0.5)]">
    <div
      class="rounded-xl bg-white dark:bg-inverse-surface p-4 shadow-[inset_0_0_0_1px_rgba(0,0,0,0.15),0_0_0_1px_rgba(255,255,255,0.8)] dark:shadow-[inset_0_0_0_1px_rgba(255,255,255,0.1),0_0_0_1px_rgba(0,0,0,0.5)]"
    >
      <h3
        class="font-headline-md font-bold text-primary dark:text-inverse-on-surface mb-2"
      >
        Subscribe
      </h3>
      <p
        class="font-body-md text-body-md text-on-surface-variant mb-4 text-sm leading-snug"
      >
        Get the best of the web design feed delivered weekly.
      </p>
      <a
        href="/newsletter/"
        class="block text-center w-full bg-secondary text-on-secondary font-label-md text-sm py-2 rounded-lg hover:opacity-90 active:scale-95 transition-all font-semibold"
      >
        Join newsletter
      </a>
      <a
        href="/rss.xml"
        data-astro-reload
        class="block text-center w-full border border-outline text-primary dark:text-inverse-on-surface font-label-md text-sm py-2 rounded-lg hover:bg-surface-variant transition-all font-semibold mt-2"
      >
        Subscribe to RSS
      </a>
    </div>
  </div>
</aside>
