---
import { CATEGORIES, SITE_TITLE, SITE_LOGO } from '../../consts';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navLinks = [
  { href: '/featured/', label: 'Featured' },
  { href: '/newsletter/', label: 'Newsletter' },
  { href: '/about/', label: 'About' },
];

function isActive(href: string): boolean {
  return href === '/' ? currentPath === '/' : currentPath.startsWith(href);
}
---

<header
  class="bg-surface dark:bg-inverse-surface sticky top-0 border-b border-[#dee2e6] dark:border-outline-variant z-50 transition-colors duration-300"
>
  <div class="grid grid-cols-[1fr_auto_1fr] items-center px-gutter w-full h-16 max-w-container-max mx-auto">
    <div class="flex items-center gap-stack-lg justify-self-start">
      <button
        id="mobile-menu-btn"
        class="md:hidden text-primary dark:text-inverse-on-surface p-2 -ml-2 rounded-lg hover:bg-surface-variant transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="material-symbols-outlined" aria-hidden="true">menu</span>
      </button>

      <a href="/" class="flex items-center gap-2" aria-label={SITE_TITLE}>
        <img src={SITE_LOGO} alt={SITE_TITLE} class="h-6 w-auto object-contain dark:invert" width="160" height="24" />
      </a>
    </div>

    <nav aria-label="Primary" class="hidden md:flex items-center justify-self-center gap-stack-md">
      {navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class={`font-label-md text-label-md px-3 py-1.5 rounded-md transition-colors hover:text-secondary ${
            isActive(link.href)
              ? 'text-primary dark:text-inverse-on-surface font-bold'
              : 'text-on-surface-variant'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4 justify-self-end">
      <div id="desktop-search" class="hidden lg:flex items-center">
        <form
          id="desktop-search-form"
          action="/search/"
          method="get"
          class="flex items-center overflow-hidden w-0 opacity-0 pointer-events-none mr-0 transition-[width,opacity,margin] duration-300 ease-out"
          role="search"
          aria-hidden="true"
          inert
        >
          <label for="site-search" class="sr-only">Search stories</label>
          <input
            id="site-search"
            type="search"
            name="q"
            placeholder="Search..."
            class="w-64 shrink-0 pl-4 pr-4 py-1.5 rounded-xl border border-[#dee2e6] dark:border-outline-variant bg-transparent text-body-md text-primary dark:text-inverse-on-surface focus:outline-none focus-visible:ring-1 focus-visible:ring-outline placeholder:text-on-surface-variant"
          />
        </form>
        <button
          id="search-toggle"
          type="button"
          class="text-primary dark:text-inverse-on-surface p-2 rounded-full hover:bg-surface-variant transition-colors"
          aria-label="Open search"
          aria-expanded="false"
          aria-controls="desktop-search-form"
        >
          <span id="search-toggle-icon" class="material-symbols-outlined block" aria-hidden="true">search</span>
        </button>
      </div>

      <a
        id="bookmarks-link"
        href="/bookmarks/"
        aria-current={isActive('/bookmarks/') ? 'page' : undefined}
        class="relative text-primary dark:text-inverse-on-surface p-2 rounded-full hover:bg-surface-variant transition-colors"
        aria-label="View bookmarks"
      >
        <span class="material-symbols-outlined block" aria-hidden="true">bookmark</span>
        <span
          id="bookmark-count"
          class="absolute -right-0.5 -top-0.5 hidden min-w-4 h-4 px-1 items-center justify-center rounded-full bg-secondary text-on-secondary text-[10px] leading-none font-bold tabular-nums"
          aria-live="polite"
          aria-atomic="true"
        ></span>
      </a>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden md:hidden absolute top-full left-0 w-full max-h-[calc(100vh-4rem)] overflow-y-auto bg-surface dark:bg-inverse-surface border-b border-[#dee2e6] dark:border-outline-variant shadow-lg transition-all duration-300 origin-top"
  >
    <nav aria-label="Mobile" class="flex flex-col p-4 gap-2">
      <form action="/search/" method="get" class="relative w-full mb-4" role="search">
        <label for="mobile-search" class="sr-only">Search stories</label>
        <input
          id="mobile-search"
          type="search"
          name="q"
          placeholder="Search articles..."
          class="w-full pl-4 pr-4 py-2 rounded-lg border border-[#dee2e6] dark:border-outline-variant bg-transparent text-body-md text-primary dark:text-inverse-on-surface focus:outline-none"
        />
      </form>

      <div class="mb-3 pb-4 border-b border-[#dee2e6] dark:border-outline-variant">
        <h2 class="px-3 mb-2 text-label-md font-bold text-primary dark:text-inverse-on-surface">
          Categories
        </h2>
        <div class="flex flex-col gap-1">
          {CATEGORIES.map((category) => {
            const href = `/category/${category.slug}/`;

            return (
              <a
                href={href}
                aria-current={isActive(href) ? 'page' : undefined}
                class={`p-3 rounded-lg flex items-center gap-3 transition-colors ${
                  isActive(href)
                    ? 'font-bold text-primary dark:text-inverse-on-surface bg-surface-variant'
                    : 'text-on-surface-variant hover:bg-surface-variant'
                }`}
              >
                <span class="material-symbols-outlined text-[20px]" aria-hidden="true">
                  {category.icon}
                </span>
                {category.label}
              </a>
            );
          })}
        </div>
      </div>

      {navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class={`p-3 rounded-lg transition-colors ${
            isActive(link.href)
              ? 'font-bold text-primary dark:text-inverse-on-surface bg-surface-variant'
              : 'text-on-surface-variant hover:bg-surface-variant'
          }`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/bookmarks/"
        aria-current={isActive('/bookmarks/') ? 'page' : undefined}
        class={`p-3 rounded-lg transition-colors ${
          isActive('/bookmarks/')
            ? 'font-bold text-primary dark:text-inverse-on-surface bg-surface-variant'
            : 'text-on-surface-variant hover:bg-surface-variant'
        }`}
      >
        Bookmarks
      </a>
    </nav>
  </div>
</header>

<script>
  import { BOOKMARKS_CHANGED_EVENT, getBookmarks } from '../../lib/bookmarks-client';

  // The whole <header> is swapped in fresh on every ClientRouter navigation
  // (it re-renders per page so `aria-current` tracks the new URL), so its
  // element-specific listeners have to be rebound each time. Document/window
  // listeners are attached once at the bottom and look up elements fresh at
  // event time instead of closing over references that go stale on swap.

  function setSearchOpen(open: boolean, returnFocus = false) {
    const desktopSearchForm = document.getElementById('desktop-search-form');
    const searchToggle = document.getElementById('search-toggle');
    const searchToggleIcon = document.getElementById('search-toggle-icon');
    const siteSearchInput = document.getElementById('site-search') as HTMLInputElement | null;
    if (!desktopSearchForm || !searchToggle) return;

    desktopSearchForm.classList.toggle('w-0', !open);
    desktopSearchForm.classList.toggle('opacity-0', !open);
    desktopSearchForm.classList.toggle('pointer-events-none', !open);
    desktopSearchForm.classList.toggle('mr-0', !open);
    desktopSearchForm.classList.toggle('w-64', open);
    desktopSearchForm.classList.toggle('opacity-100', open);
    desktopSearchForm.classList.toggle('mr-2', open);
    desktopSearchForm.setAttribute('aria-hidden', String(!open));
    desktopSearchForm.toggleAttribute('inert', !open);
    searchToggle.setAttribute('aria-expanded', String(open));
    searchToggle.setAttribute('aria-label', open ? 'Close search' : 'Open search');
    if (searchToggleIcon) searchToggleIcon.textContent = open ? 'close' : 'search';

    if (open) {
      requestAnimationFrame(() => siteSearchInput?.focus());
    } else if (returnFocus) {
      searchToggle.focus();
    }
  }

  function syncBookmarkCount() {
    const bookmarksLink = document.getElementById('bookmarks-link');
    const bookmarkCount = document.getElementById('bookmark-count');
    const count = getBookmarks().length;

    if (bookmarkCount) {
      bookmarkCount.textContent = count > 99 ? '99+' : String(count);
      bookmarkCount.classList.toggle('hidden', count === 0);
      bookmarkCount.classList.toggle('flex', count > 0);
    }

    bookmarksLink?.setAttribute('aria-label', `View bookmarks (${count} saved)`);
  }

  function initHeader() {
    const searchToggle = document.getElementById('search-toggle');
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (!searchToggle?.dataset.searchInit) {
      searchToggle?.setAttribute('data-search-init', 'true');
      searchToggle?.addEventListener('click', () => {
        setSearchOpen(searchToggle.getAttribute('aria-expanded') !== 'true');
      });
    }

    if (!mobileBtn?.dataset.mobileInit) {
      mobileBtn?.setAttribute('data-mobile-init', 'true');
      mobileBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('hidden') === false;
        mobileMenu?.classList.toggle('hidden');
        mobileBtn.setAttribute('aria-expanded', String(!isOpen));
        mobileBtn.innerHTML = !isOpen
          ? '<span class="material-symbols-outlined" aria-hidden="true">close</span>'
          : '<span class="material-symbols-outlined" aria-hidden="true">menu</span>';
      });
    }

    syncBookmarkCount();
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);

  // Document/window listeners: the targets they check are looked up fresh
  // each time, so these are safe to register exactly once and never rebind.
  document.addEventListener('keydown', (event) => {
    const searchToggle = document.getElementById('search-toggle');
    if (event.key === 'Escape' && searchToggle?.getAttribute('aria-expanded') === 'true') {
      setSearchOpen(false, true);
    }
  });

  document.addEventListener('click', (event) => {
    const desktopSearch = document.getElementById('desktop-search');
    const searchToggle = document.getElementById('search-toggle');
    if (
      searchToggle?.getAttribute('aria-expanded') === 'true'
      && event.target instanceof Node
      && !desktopSearch?.contains(event.target)
    ) {
      setSearchOpen(false);
    }
  });

  window.addEventListener(BOOKMARKS_CHANGED_EVENT, syncBookmarkCount);
  window.addEventListener('storage', (event) => {
    if (event.key === 'wdf:bookmarks') syncBookmarkCount();
  });
</script>
