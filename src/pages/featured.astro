---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import StoryCard from '../components/ui/StoryCard.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import SeoBlurb from '../components/ui/SeoBlurb.astro';
import PageHeading from '../components/ui/PageHeading.astro';
import ViewToggle from '../components/ui/ViewToggle.astro';

const stories = (await getCollection('stories', ({ data }) => data.featured)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<BaseLayout
  title="Featured"
  description="Editor's picks — the stories that make it into the weekly newsletter digest."
>
  <Breadcrumb items={[{ label: 'Featured', href: '/featured' }]} />

  <PageHeading>
    Editor's Picks
    <ViewToggle slot="actions" />
  </PageHeading>
  <p class="text-on-surface-variant mb-stack-md text-sm">
    The best stories of the week, hand-picked. Powers the <a href="/newsletter" class="underline hover:text-primary dark:hover:text-inverse-on-surface">weekly digest</a>.
  </p>

  <ol data-story-list class="flex flex-col gap-stack-md list-none p-0 m-0">
    {stories.map((story, i) => (
      <li>
        <StoryCard story={story} priority={i < 3} />
      </li>
    ))}
  </ol>

  {stories.length === 0 && (
    <p class="text-on-surface-variant py-stack-lg text-center">No featured stories yet this week.</p>
  )}

  <SeoBlurb title="About Featured Stories on Web Design Feed">
    <p>
      Featured stories are the editor's picks from across UI design, front-end and back-end development,
      tools, and careers.
    </p>
    <p>
      Each selection is chosen for its practical insight, original thinking, or usefulness to people who
      design and build for the web.
    </p>
    <p>
      Browse the latest picks here or get the highlights delivered in the weekly newsletter digest. Every
      story links directly to the original author and source.
    </p>
  </SeoBlurb>
</BaseLayout>
