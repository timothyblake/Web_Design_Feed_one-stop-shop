---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/ui/StoryCard.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import SeoBlurb from '../../components/ui/SeoBlurb.astro';
import PageHeading from '../../components/ui/PageHeading.astro';
import ViewToggle from '../../components/ui/ViewToggle.astro';
import {
  CATEGORIES,
  categoryPageTitle,
  categoryUrlSlug,
  CATEGORY_BLURBS,
  CATEGORY_DESCRIPTIONS,
  type CategorySlug,
  SITE_URL,
} from '../../consts';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return CATEGORIES.map((category) => ({
    // The URL segment is slugified from the page title, so it only diverges
    // from `category.slug` for categories with a longer page title (e.g.
    // front-end → front-end-development) — story filtering below still keys
    // off the original `category.slug`, which is what's stored in Sanity.
    params: { slug: categoryUrlSlug(category.slug) },
    props: {
      categorySlug: category.slug,
      stories: stories
        .filter((s) => s.data.category === category.slug)
        .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()),
    },
  }));
}

interface Props {
  categorySlug: CategorySlug;
  stories: CollectionEntry<'stories'>[];
}

const { categorySlug, stories } = Astro.props;
const urlSlug = categoryUrlSlug(categorySlug);
const label = categoryPageTitle(categorySlug);
const blurb = CATEGORY_BLURBS[categorySlug];
const shortDescription = CATEGORY_DESCRIPTIONS[categorySlug];
const description = `The latest ${label} stories — curated links to the best articles across the web.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${label} stories`,
  url: `${SITE_URL}/category/${urlSlug}`,
  itemListElement: stories.map((story, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: story.data.url,
    name: story.data.title,
  })),
};
---

<BaseLayout title={label} description={description} activeCategory={categorySlug} structuredData={jsonLd}>
  <Breadcrumb items={[{ label, href: `/category/${urlSlug}` }]} />

  <PageHeading>
    {label}
    <ViewToggle slot="actions" />
  </PageHeading>

  <p class="text-on-surface-variant mb-stack-md text-sm leading-relaxed">
    {shortDescription}
  </p>

  <ol data-story-list class="flex flex-col gap-stack-md list-none p-0 m-0">
    {stories.map((story, i) => (
      <li>
        <StoryCard story={story} priority={i < 3} />
      </li>
    ))}
  </ol>

  {stories.length === 0 && (
    <p class="text-on-surface-variant py-stack-lg text-center">No {label} stories yet — check back soon.</p>
  )}

  <SeoBlurb title={`About ${label} on Web Design Feed`}>
    {blurb.map((paragraph) => <p>{paragraph}</p>)}
  </SeoBlurb>
</BaseLayout>
