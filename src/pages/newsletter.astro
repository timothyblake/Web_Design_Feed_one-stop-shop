---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import NewsletterCTA from '../components/ui/NewsletterCTA.astro';
import PageHeading from '../components/ui/PageHeading.astro';
---

<BaseLayout
  title="Newsletter"
  description="Subscribe to the weekly Web Design Feed digest — the best UI design, front-end and back-end stories, every Friday."
>
  <Breadcrumb items={[{ label: 'Newsletter', href: '/newsletter' }]} />

  <PageHeading>The Weekly Digest</PageHeading>
  <p class="text-on-surface-variant mb-stack-lg leading-relaxed">
    Once a week, we round up the <a href="/featured" class="underline hover:text-primary">editor's picks</a>
    from the site into a single email. No algorithm, no noise — just the stories worth your Friday coffee.
  </p>

  <NewsletterCTA />

  <section class="mt-stack-lg" aria-labelledby="past-issues-heading">
    <h2 id="past-issues-heading" class="font-headline-md font-bold text-primary text-lg mb-2">
      Past issues
    </h2>
    <p class="text-on-surface-variant text-sm">
      The archive lives on Buttondown —
      <a href="https://buttondown.email/webdesignfeed/archive" class="underline hover:text-primary" target="_blank" rel="noopener noreferrer">
        browse past issues
        <span class="material-symbols-outlined !text-[15px] ml-[5px] align-middle" aria-hidden="true">open_in_new</span>
      </a>.
    </p>
  </section>
</BaseLayout>
